{
  "name": "marketing-journey-builder",
  "version": "1.0.0",
  "description": "Marketing Journey Builder — Heroku + Salesforce Canvas",
  "main": "server.js",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"cd client && npm start\"",
    "build": "cd client && npm install && npm run build",
    "heroku-postbuild": "cd client && npm install && npm run build",
    "migrate": "node db/migrate.js",
    "worker": "node src/worker/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "express-session": "^1.18.1",
    "pg": "^8.13.0",
    "pg-pool": "^3.7.0",
    "jsforce": "^3.6.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.25.0",
    "socket.io": "^4.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "archiver": "^7.0.1",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.5",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "concurrently": "^9.1.0"
  }
}

{
  "name": "Marketing Journey Builder",
  "description": "A drag-and-drop marketing journey builder — standalone Heroku application. Canvas integration preserved for future use.",
  "repository": "https://github.com/braymondSFDC/Marketing-Application-Heroku",
  "keywords": ["heroku", "journey-builder", "marketing", "react-flow", "drag-and-drop"],
  "stack": "heroku-24",
  "env": {
    "SESSION_SECRET": {
      "description": "Secret for Express session encryption",
      "generator": "secret"
    },
    "WEBHOOK_SECRET": {
      "description": "Shared secret for verifying webhook payloads (optional in standalone mode)",
      "required": false
    },
    "SF_ORG_ID": {
      "description": "Salesforce Org ID for standalone mode (optional)",
      "required": false
    },
    "SF_ORG_NAME": {
      "description": "Display name for the org (optional)",
      "value": "Marketing Journey Builder"
    },
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    }
  },
  "formation": {
    "web": { "quantity": 1, "size": "standard-1x" },
    "worker": { "quantity": 1, "size": "standard-1x" }
  },
  "addons": [
    { "plan": "heroku-postgresql:essential-0" },
    { "plan": "heroku-redis:mini" }
  ],
  "buildpacks": [
    { "url": "heroku/nodejs" }
  ]
}

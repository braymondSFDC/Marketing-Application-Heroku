# ── Standalone Mode Configuration ──
NODE_ENV=development
PORT=3001

# Session
SESSION_SECRET=your-session-secret-here

# Database (Heroku provides DATABASE_URL automatically)
DATABASE_URL=postgresql://localhost:5432/journey_builder

# Redis (Heroku provides REDIS_URL automatically)
REDIS_URL=redis://localhost:6379

# Optional: Webhook secret for engagement event verification
WEBHOOK_SECRET=your-webhook-secret-here

# Optional: Org context (defaults are auto-generated in standalone mode)
# SF_ORG_ID=00Dxx0000000000
# SF_ORG_NAME=My Marketing Org
# SF_USERNAME=admin@example.com

# ── Future Canvas Integration (uncomment when Canvas license available) ──
# CANVAS_CONSUMER_SECRET=your-canvas-consumer-secret
# SF_CLIENT_ID=your-connected-app-consumer-key
# SF_CLIENT_SECRET=your-connected-app-consumer-secret
# SF_LOGIN_URL=https://login.salesforce.com
# SF_INSTANCE_URL=https://your-org.my.salesforce.com

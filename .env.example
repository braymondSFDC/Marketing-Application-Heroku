# Salesforce Connected App
CANVAS_CONSUMER_SECRET=your_consumer_secret_here
SF_CLIENT_ID=your_consumer_key_here
SF_CLIENT_SECRET=your_consumer_secret_here
SF_LOGIN_URL=https://login.salesforce.com

# Webhook
WEBHOOK_SECRET=your_webhook_shared_secret

# Session
SESSION_SECRET=your_session_secret

# Database (auto-provisioned by Heroku)
